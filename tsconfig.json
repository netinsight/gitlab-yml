{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "rootDir": "src",
        "outDir": "lib",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": false,
        "strictPropertyInitialization": false,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*"]
}
